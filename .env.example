# ============================================================
# Charge Platform — Environment variables (template)
# ============================================================
# Copy this file to `.env.local` and fill in the values.
# Vercel: set the same keys via Project → Settings → Environment Variables.
# ============================================================

# ----- Supabase (required) -----
# From Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# Service-role key bypasses RLS — server-only, NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ----- Anthropic / Claude (required for AI agents) -----
ANTHROPIC_API_KEY=sk-ant-...
# Optional override of the default Sonnet 4.5 model
ANTHROPIC_MODEL=claude-sonnet-4-5

# ----- Stripe (required for billing webhook) -----
STRIPE_SECRET_KEY=sk_live_or_test_...
# From Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ----- AMPECO CPMS (required for charger telemetry) -----
AMPECO_API_BASE_URL=https://api.ampeco.com
AMPECO_API_KEY=ampeco_...
# Shared secret used to HMAC-sign incoming webhooks from AMPECO
AMPECO_WEBHOOK_SECRET=replace-with-strong-random
# Optional: switch CPMS provider (default: ampeco)
CPMS_PROVIDER=ampeco

# ----- Cron jobs -----
# Vercel Cron sends `Authorization: Bearer ${CRON_SECRET}` on every scheduled hit
CRON_SECRET=replace-with-strong-random

# ----- Email (Resend) -----
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Charge <hello@charge.be>

# ----- Observability (optional but recommended) -----
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# ----- Background jobs (Inngest, optional) -----
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
